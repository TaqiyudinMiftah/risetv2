{
    "name": "CAER_S_Official_CAERNet",
    "n_gpu": 2,
    "arch": {
        "type": "CAERSNet",
        "args": {
            "use_face": true,
            "use_context": true,
            "concat": false
        }
    },
    "train_loader": {
        "type": "CAERSDataLoader",
        "args": {
            "root": "data/CAER-S/train",
            "detect_file": "data/train.txt",
            "train": true,
            "batch_size": 64,
            "shuffle": true,
            "num_workers": 4
        }
    },
    "val_loader": {
        "type": "CAERSDataLoader",
        "args": {
            "root": "data/CAER-S/train",
            "detect_file": "data/val.txt",
            "train": false,
            "batch_size": 64,
            "shuffle": false,
            "num_workers": 4
        }
    },
    "test_loader": {
        "type": "CAERSDataLoader",
        "args": {
            "root": "data/CAER-S/test",
            "detect_file": "data/test.txt",
            "train": false,
            "batch_size": 64,
            "shuffle": false,
            "num_workers": 4
        }
    },
    "optimizer": {
        "type": "Adam",
        "args": {
            "lr": 0.0001,
            "weight_decay": 0,
            "amsgrad": true
        }
    },
    "loss": "cross_entropy",
    "metrics": [
        "accuracy"
    ],
    "lr_scheduler": {
        "type": "StepLR",
        "args": {
            "step_size": 50,
            "gamma": 0.1
        }
    },
    "trainer": {
        "epochs": 50,
        "save_dir": "official_runs",
        "save_period": 1,
        "verbosity": 2,
        "monitor": "max val_accuracy",
        "early_stop": 10,
        "tensorboard": true
    }
}
